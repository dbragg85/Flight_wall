# FlightWall Mobile - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# RapidAPI Flight/Aircraft API Configuration
# ===========================================
# Get your API key from https://rapidapi.com
# Search for flight tracking APIs (e.g., AeroDataBox, FlightAware, ADS-B Exchange)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=your_api_host_here
RAPIDAPI_URL=https://your-api-endpoint-here

# ===========================================
# ntfy Push Notification Configuration
# ===========================================
# Create a unique private topic name (random string recommended)
# Install ntfy app on your phone and subscribe to this topic
# Example: flightwall-abc123-private
NTFY_TOPIC=your_private_topic_here

# ===========================================
# Location Configuration
# ===========================================
# Your home/monitoring location coordinates
# Find your coordinates at https://www.latlong.net/
HOME_LAT=40.7128
HOME_LON=-74.0060

# ===========================================
# Search Parameters
# ===========================================
# Search radius in nautical miles (1 NM = 1.852 km)
SEARCH_RADIUS_NM=25

# How often to poll the API (in minutes)
# WARNING: Setting this below 5 may exceed API rate limits
POLL_INTERVAL_MINUTES=5

# Altitude filters (in feet)
MIN_ALTITUDE_FT=0
MAX_ALTITUDE_FT=45000

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
